{
  "name": "@webshr/unocss-preset",
  "version": "0.1.0",
  "type": "module",
  "description": "Non-opinionated UnoCSS preset with fluid type/space scales, color families with alpha variants, and CSS-variable-first token system.",
  "author": "Webshore <hello@webshore.eu>",
  "license": "MIT",
  "keywords": [
    "unocss",
    "unocss-preset",
    "webshore"
  ],
  "types": "./dist/index.d.mts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./reset.css": "./src/reset.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/reset.css"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@unocss/core": "^66.6.8",
    "@unocss/preset-mini": "^66.6.8"
  },
  "devDependencies": {
    "@unocss/core": "^66.6.8",
    "@unocss/preset-mini": "^66.6.8",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
